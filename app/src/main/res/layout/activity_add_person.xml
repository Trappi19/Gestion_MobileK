<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".AddPersonActivity">

    <!-- Contenu scrollable -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Bandeau -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#4A90E2"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btnBackAdd"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Retour"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@android:color/white"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Ajouter une personne"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <View android:layout_width="48dp" android:layout_height="48dp"/>
        </LinearLayout>

        <!-- Formulaire scrollable avec padding bas pour pas cacher sous le FAB -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingBottom="80dp"
                android:background="@android:color/transparent">

                <!-- Nom -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nom"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ex: Jean"
                    android:inputType="textPersonName"
                    android:padding="12dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Date -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dernier passage"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnPickDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choisir une date"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvSelectedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aucune date sélectionnée"
                    android:textColor="#888888"
                    android:layout_marginBottom="24dp"/>

                <!-- Aime Ingrédients -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aime particulièrement – Ingrédients"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/containerLikesIngredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnAddLikeIngredient"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Ajouter ingrédient aimé"
                    android:layout_marginBottom="24dp"/>

                <!-- Aime Plats -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aime particulièrement – Plats"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/containerLikesPlats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnAddLikePlat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Ajouter plat aimé"
                    android:layout_marginBottom="24dp"/>

                <!-- N'aime pas Ingrédients -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="N'aime pas – Ingrédients"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/containerDislikesIngredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnAddDislikeIngredient"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Ajouter ingrédient non aimé"
                    android:layout_marginBottom="24dp"/>

                <!-- N'aime pas Plats -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="N'aime pas – Plats"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/containerDislikesPlats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnAddDislikePlat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Ajouter plat non aimé"
                    android:layout_marginBottom="32dp"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Bouton Ajouter flottant en bas à droite (comme un FAB) -->
    <Button
        android:id="@+id/btnConfirmAdd"
        android:layout_width="171dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="Ajouter"
        android:textColor="@android:color/white"
        app:backgroundTint="#7B68EE" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
