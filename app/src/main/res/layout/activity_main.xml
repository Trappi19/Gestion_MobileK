<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- Header avec titre et menu 3 points -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#4A90E2"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="Last Meal Memory"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menu"
            android:scaleType="centerInside"
            android:src="@drawable/ic_more_vert"
            app:tint="@android:color/white" />

    </LinearLayout>

    <!-- Contenu central -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Stats depuis la BDD -->
        <TextView
            android:id="@+id/tvStatsPlats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Plats: 0"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/tvStatsHistorique"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Historique: 0"
            android:textColor="@android:color/black" />

        <!-- 4 boutons en grille 2x2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPlats"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_margin="12dp"
                android:layout_weight="1"
                android:text="Plats" />

            <Button
                android:id="@+id/btnPersonnes"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_margin="12dp"
                android:layout_weight="1"
                android:text="Personnes" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnIngredients"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_margin="12dp"
                android:layout_weight="1"
                android:text="Ingrédients" />

            <Button
                android:id="@+id/btnFutureRecettes"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_margin="12dp"
                android:layout_weight="1"
                android:text="Future Recettes" />

        </LinearLayout>

    </LinearLayout>

    <!-- Footer noir avec bouton Historique -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/btnHistorique"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Historique"
            android:textColor="@android:color/white" />

    </LinearLayout>

</LinearLayout>
